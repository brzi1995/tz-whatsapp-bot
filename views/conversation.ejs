<%- include('partials/head', { title: 'Razgovor' }) %>
<%- include('partials/sidebar', { activePage: 'conversations' }) %>

<style>
  /* Full-height chat layout */
  main.content { padding: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

  .chat-header { flex-shrink: 0; padding: 14px 24px; background: var(--surface); border-bottom: 1px solid var(--border); }
  .chat-header .back-link { margin-bottom: 10px; }

  .chat-messages { flex: 1; overflow-y: auto; padding: 20px 24px; background: var(--bg); }

  .chat-footer { flex-shrink: 0; padding: 12px 16px; background: var(--surface); border-top: 1px solid var(--border); }
  .chat-footer form { display: flex; gap: 10px; }
  .chat-footer input { flex: 1; margin: 0; }
  .chat-footer button { flex-shrink: 0; }

  /* Message rows */
  .msg-row { display: flex; margin-bottom: 10px; }
  .msg-row.from-user  { justify-content: flex-start; }
  .msg-row.from-admin { justify-content: flex-end; }

  .msg-bubble {
    max-width: 68%;
    padding: 9px 14px;
    border-radius: 14px;
    font-size: 13.5px;
    line-height: 1.55;
    word-break: break-word;
  }
  .from-user  .msg-bubble { background: #fff; border: 1px solid var(--border); border-bottom-left-radius: 4px; }
  .from-admin .msg-bubble { background: var(--blue); color: #fff; border-bottom-right-radius: 4px; }

  .msg-meta { font-size: 11px; margin-top: 4px; color: var(--muted); display: flex; align-items: center; gap: 5px; }
  .from-admin .msg-meta { color: rgba(255,255,255,.6); justify-content: flex-end; }

  .intent-tag {
    font-size: 10px; font-weight: 600;
    background: rgba(0,0,0,.06); color: var(--muted);
    border-radius: 4px; padding: 1px 5px;
  }
  .from-admin .intent-tag { background: rgba(255,255,255,.2); color: rgba(255,255,255,.8); }

  @media (max-width: 768px) {
    .chat-header { padding: 12px 16px; }
    .chat-messages { padding: 12px 16px; }
    .msg-bubble { max-width: 85%; font-size: 14px; }
  }
</style>

<main class="content">

  <!-- Header -->
  <div class="chat-header">
    <a href="/admin/conversations" class="back-link">&#8592; Razgovori</a>
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-top:6px">
      <div>
        <div style="font-size:15px;font-weight:700;color:var(--text)"><%= (userPhone || '').replace('whatsapp:', '') %></div>
        <div style="font-size:12px;color:var(--muted);margin-top:2px"><%= (messages || []).length %> poruka</div>
      </div>
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
        <span id="to-badge" style="padding:4px 12px;border-radius:20px;font-size:12px;font-weight:700;background:<%= takeover ? '#f0fdf4' : '#f1f5f9' %>;color:<%= takeover ? '#16a34a' : '#64748b' %>">
          <%= takeover ? '🤝 Operater odgovara' : '🤖 Bot odgovara' %>
        </span>
        <button id="to-btn" class="btn btn-sm" onclick="toggleTakeover()"
                style="background:<%= takeover ? '#16a34a' : '#64748b' %>;color:#fff">
          <%= takeover ? 'Deaktiviraj' : 'Preuzmi razgovor' %>
        </button>
      </div>
    </div>
  </div>

  <!-- Messages -->
  <div class="chat-messages" id="chat-messages">
    <% if (!messages || messages.length === 0) { %>
      <div class="empty">Nema poruka u ovom razgovoru.</div>
    <% } else {
         messages.forEach(function(msg) {
           const isAdmin   = msg.intent === 'admin_reply';
           const rowClass  = isAdmin ? 'from-admin' : 'from-user';
           const text      = msg.message || '';
           const timeStr   = msg.created_at ? new Date(msg.created_at).toLocaleString('hr-HR') : '';
           const intentLbl = (!isAdmin && msg.intent) ? msg.intent : '';
    %>
    <div class="msg-row <%= rowClass %>">
      <div class="msg-bubble">
        <%= text %>
        <div class="msg-meta">
          <% if (timeStr) { %><span><%= timeStr %></span><% } %>
          <% if (intentLbl) { %><span class="intent-tag"><%= intentLbl %></span><% } %>
          <% if (isAdmin) { %><span class="intent-tag">admin</span><% } %>
        </div>
      </div>
    </div>
    <% }); } %>
  </div>

  <!-- Reply form -->
  <div class="chat-footer">
    <form method="POST" action="/admin/conversations/<%= encodeURIComponent(userPhone || '') %>/reply">
      <input type="text" name="message" placeholder="Upiši odgovor..." required autocomplete="off">
      <button type="submit" class="btn btn-primary">Pošalji</button>
    </form>
  </div>

</main>

<script>
  // Scroll to bottom on load
  const chatEl = document.getElementById('chat-messages');
  if (chatEl) chatEl.scrollTop = chatEl.scrollHeight;

  async function toggleTakeover() {
    const btn   = document.getElementById('to-btn');
    const badge = document.getElementById('to-badge');
    btn.disabled = true;
    btn.style.opacity = '0.6';
    try {
      const r    = await fetch('/admin/takeover/<%= tenantId %>', { method: 'POST' });
      const data = await r.json();
      if (data.success) {
        const on = data.human_takeover;
        badge.style.background = on ? '#f0fdf4' : '#f1f5f9';
        badge.style.color      = on ? '#16a34a'  : '#64748b';
        badge.textContent      = on ? '🤝 Operater odgovara' : '🤖 Bot odgovara';
        btn.style.background   = on ? '#16a34a'  : '#64748b';
        btn.textContent        = on ? 'Deaktiviraj' : 'Preuzmi razgovor';
      }
    } catch (e) {
      alert('Mrežna greška.');
    } finally {
      btn.disabled = false;
      btn.style.opacity = '1';
    }
  }
</script>

<%- include('partials/foot') %>
