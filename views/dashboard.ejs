<%- include('partials/head', { title: 'Dashboard' }) %>
<%- include('partials/sidebar', { activePage: 'dashboard' }) %>
<%
  if (locals.totalUsers      === undefined) locals.totalUsers      = 0;
  if (locals.totalMessages   === undefined) locals.totalMessages   = 0;
  if (locals.perDay          === undefined) locals.perDay          = [];
  if (locals.intents         === undefined) locals.intents         = [];
  if (locals.languages       === undefined) locals.languages       = [];
  if (locals.insights        === undefined) locals.insights        = [];
  if (locals.featuredEvents  === undefined) locals.featuredEvents  = [];
  if (locals.timeOfDay       === undefined) locals.timeOfDay       = { morning: 0, afternoon: 0, evening: 0 };

  // Language stats
  const _langNames = { hr:'🇭🇷 Hrvatski', en:'🇬🇧 English', de:'🇩🇪 Deutsch', it:'🇮🇹 Italiano', fr:'🇫🇷 Français', sv:'🇸🇪 Svenska', no:'🇳🇴 Norsk', cs:'🇨🇿 Čeština' };
  const _langTotal = languages.reduce((s,r) => s + Number(r.count), 0) || 1;
  const _topLang   = languages.length ? (_langNames[languages[0].lang] || languages[0].lang) : null;
  const _topLangPct = languages.length ? Math.round(Number(languages[0].count) / _langTotal * 100) : 0;

  // Peak activity
  const _tod = timeOfDay || {};
  const _todSlots = [
    { label:'Jutro',   icon:'🌅', val: Number(_tod.morning)||0 },
    { label:'Popodne', icon:'☀️', val: Number(_tod.afternoon)||0 },
    { label:'Večer',   icon:'🌙', val: Number(_tod.evening)||0 },
  ];
  const _peakSlot  = _todSlots.reduce((a, b) => b.val > a.val ? b : a, _todSlots[0]);
  const _peakTotal = _todSlots.reduce((s, x) => s + x.val, 0);
%>

<main class="content">
  <div class="page-header">
    <h1>Dashboard</h1>
    <p>Pregled aktivnosti vašeg WhatsApp bota</p>
  </div>

  <!-- Uvidi (inline strip) -->
  <% if (insights && insights.length) { %>
  <div class="uvidi-strip">
    <div class="uvidi-strip-title"><i data-lucide="sparkles"></i> Uvidi</div>
    <div class="uvidi-strip-items">
      <% insights.forEach(function(ins, i) { %>
        <% if (i > 0) { %><span class="uvidi-strip-sep">·</span><% } %>
        <div class="uvidi-strip-item"><%= ins.icon %> <%= ins.text %></div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- Stats grid: hero + 3 secondary -->
  <div class="stats-grid">

    <!-- Hero: total messages -->
    <div class="hero-card">
      <div class="hero-icon">
        <i data-lucide="message-circle"></i>
      </div>
      <div class="label">Ukupno poruka</div>
      <div class="hero-num"><%= totalMessages %></div>
    </div>

    <!-- Users -->
    <div class="stat-card">
      <div class="stat-card-top">
        <div class="label">Korisnici</div>
        <div class="stat-card-icon icon-blue">
          <i data-lucide="users"></i>
        </div>
      </div>
      <div class="num"><%= totalUsers %></div>
    </div>

    <!-- Top language -->
    <div class="stat-card">
      <div class="stat-card-top">
        <div class="label">Jezik</div>
        <div class="stat-card-icon icon-purple">
          <i data-lucide="globe"></i>
        </div>
      </div>
      <% if (_topLang) { %>
        <div class="num num-text"><%= _topLangPct %>%</div>
        <div class="stat-sub"><%= _topLang %></div>
      <% } else { %>
        <div class="num" style="color:var(--muted)">—</div>
      <% } %>
    </div>

    <!-- Peak activity -->
    <div class="stat-card">
      <div class="stat-card-top">
        <div class="label">Najaktivnije</div>
        <div class="stat-card-icon icon-amber">
          <i data-lucide="clock"></i>
        </div>
      </div>
      <% if (_peakTotal > 0) { %>
        <div class="num num-text"><%= _peakSlot.icon %> <%= _peakSlot.label %></div>
      <% } else { %>
        <div class="num" style="color:var(--muted)">—</div>
      <% } %>
    </div>

  </div>

  <!-- Featured Events -->
  <div class="chart-wrap">
    <div class="chart-header">
      <div style="display:flex;align-items:center;gap:8px">
        <h2>Izdvojeni događaji</h2>
      </div>
      <a href="/admin/events" class="btn btn-secondary btn-sm">
        <i data-lucide="settings-2"></i> Upravljaj
      </a>
    </div>
    <% if (!featuredEvents || !featuredEvents.length) { %>
      <div style="padding:12px 0;color:var(--muted);font-size:13px">
        Nema izdvojenih događaja —
        <a href="/admin/events" style="color:var(--blue);text-decoration:none;font-weight:600">označi ih u listi</a>
      </div>
    <% } else { %>
      <div style="display:flex;flex-direction:column;gap:7px">
        <% featuredEvents.forEach(function(ev) {
             const dateStr = ev.date ? new Date(ev.date).toLocaleDateString('hr-HR') : '—';
        %>
        <div class="feat-row">
          <div class="feat-body">
            <div class="feat-title"><%= ev.title %></div>
            <% if (ev.description) { %>
              <div class="feat-desc"><%= ev.description %></div>
            <% } %>
          </div>
          <div class="feat-date"><%= dateStr %></div>
        </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Chart: messages per day -->
  <div class="chart-wrap">
    <div class="chart-header">
      <h2>Poruke po danu</h2>
      <span class="chart-badge">Posljednjih 7 dana</span>
    </div>
    <canvas id="msgChart" height="80"></canvas>
  </div>

  <!-- Intent distribution -->
  <% const intentLabels = {
       faq:'Opće informacije',
       weather:'Vrijeme', weather_current:'Vrijeme', weather_tomorrow:'Vrijeme', weather_multi:'Vrijeme',
       events:'Događaji',
       ai:'AI razgovor',
       other:'Ostalo'
     };
     const intentColors = { faq:'#3b82f6', weather:'#38bdf8', events:'#10b981', ai:'#8b5cf6' };
     const _filteredIntents = intents.filter(r => r.intent !== 'admin_reply' && r.intent !== 'fallback');
     const intentTotal  = _filteredIntents.reduce((s,r) => s + Number(r.count), 0) || 1;
  %>
  <% if (_filteredIntents.length) { %>
  <div class="chart-wrap" style="margin-bottom:0">
    <div class="chart-header">
      <h2>Upiti turista</h2>
      <span class="chart-badge">Po tipu</span>
    </div>
    <% _filteredIntents.forEach(function(r) {
         const pct = Math.round(Number(r.count) / intentTotal * 100);
         const col = intentColors[r.intent] || '#94a3b8';
         const lbl = intentLabels[r.intent] || r.intent;
    %>
      <div class="ibar">
        <div class="ibar-label">
          <span><%= lbl %></span>
          <span class="ibar-count"><%= r.count %> (<%= pct %>%)</span>
        </div>
        <div class="ibar-track">
          <div class="ibar-fill" style="width:<%= pct %>%;background:<%= col %>"></div>
        </div>
      </div>
    <% }); %>
  </div>
  <% } %>

</main>

<style>
.feat-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 14px;
  background: rgba(245,158,11,0.05);
  border-radius: 11px;
  border: 1px solid rgba(245,158,11,0.15);
  transition: background .15s, border-color .15s;
}
.feat-row:hover {
  background: rgba(245,158,11,0.08);
  border-color: rgba(245,158,11,0.25);
}
.feat-body { flex: 1; min-width: 0; }
.feat-title { font-weight: 700; font-size: 13px; color: var(--text); }
.feat-desc { font-size: 12px; color: var(--muted); margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.feat-date {
  font-size: 11.5px; font-weight: 600;
  color: #fbbf24;
  background: rgba(245,158,11,0.1);
  border: 1px solid rgba(245,158,11,0.2);
  padding: 3px 9px; border-radius: 20px;
  white-space: nowrap; flex-shrink: 0;
}

.ibar { margin-bottom: 11px; }
.ibar:last-child { margin-bottom: 0; }
.ibar-label { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 5px; font-weight: 600; color: var(--text); }
.ibar-count { color: var(--muted); font-weight: 400; }
.ibar-track { background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 20px; height: 6px; overflow: hidden; }
.ibar-fill  { height: 100%; border-radius: 20px; transition: width .5s cubic-bezier(.4,0,.2,1); opacity: 0.85; }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
(function () {
  const today  = new Date();
  const labels = [];
  const dataMap = {};

  <% perDay.forEach(function(row) {
    const d = row.day instanceof Date ? row.day.toISOString().slice(0,10) : String(row.day).slice(0,10);
  %>
  dataMap['<%= d %>'] = <%= row.count %>;
  <% }); %>

  for (let i = 6; i >= 0; i--) {
    const d = new Date(today);
    d.setDate(d.getDate() - i);
    labels.push(d.toLocaleDateString('hr-HR', { weekday:'short', day:'numeric', month:'numeric' }));
    const key = d.toISOString().slice(0, 10);
    if (!dataMap[key]) dataMap[key] = 0;
  }
  const values = [];
  for (let i = 6; i >= 0; i--) {
    const d = new Date(today);
    d.setDate(d.getDate() - i);
    values.push(dataMap[d.toISOString().slice(0, 10)] || 0);
  }

  const ctx = document.getElementById('msgChart').getContext('2d');
  const gradient = ctx.createLinearGradient(0, 0, 0, 220);
  gradient.addColorStop(0, 'rgba(59,130,246,0.75)');
  gradient.addColorStop(1, 'rgba(59,130,246,0.04)');

  new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: 'Poruke',
        data: values,
        backgroundColor: gradient,
        borderRadius: 8,
        borderSkipped: false,
        hoverBackgroundColor: 'rgba(96,165,250,0.9)',
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#0d0d0f',
          titleColor: '#71717a',
          bodyColor: '#ededef',
          borderColor: 'rgba(255,255,255,0.08)',
          borderWidth: 1,
          padding: 11,
          cornerRadius: 10,
          callbacks: { label: c => ` ${c.parsed.y} poruka` }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: { precision: 0, color: '#52525b', font: { size: 11 } },
          grid: { color: 'rgba(255,255,255,0.04)', drawBorder: false }
        },
        x: {
          ticks: { color: '#52525b', font: { size: 11 } },
          grid: { display: false }
        }
      }
    }
  });
})();
</script>

<%- include('partials/foot') %>
