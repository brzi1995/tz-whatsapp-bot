<%- include('partials/head', { title: 'Dashboard' }) %>
<%- include('partials/sidebar', { activePage: 'dashboard' }) %>

<main class="content">
  <div class="page-header">
    <h1>Dashboard</h1>
    <p>Pregled aktivnosti vašeg WhatsApp bota</p>
  </div>

  <!-- AI Insights -->
  <div style="background:linear-gradient(135deg,#1e3a5f 0%,#1e40af 100%);border-radius:14px;padding:22px 28px;margin-bottom:28px;color:#fff;box-shadow:0 4px 20px rgba(37,99,235,.25)">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
      <span style="font-size:20px">✨</span>
      <span style="font-size:15px;font-weight:700;letter-spacing:-.2px">AI Insights</span>
    </div>
    <% if (!insights.length) { %>
      <p style="color:#93c5fd;font-size:14px;margin:0">No data yet — insights will appear as users interact.</p>
    <% } else { %>
      <div style="display:flex;flex-wrap:wrap;gap:12px">
        <% insights.forEach(function(ins) { %>
          <div style="background:rgba(255,255,255,.12);border-radius:10px;padding:10px 16px;display:flex;align-items:center;gap:9px;font-size:14px;font-weight:500;flex:1;min-width:220px;backdrop-filter:blur(4px)">
            <span style="font-size:18px;flex-shrink:0"><%= ins.icon %></span>
            <span><%= ins.text %></span>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <div class="cards">
    <div class="stat-card">
      <div class="stat-card-top">
        <div class="label">Ukupno korisnika</div>
        <div class="stat-card-icon icon-blue">👥</div>
      </div>
      <div class="num"><%= totalUsers %></div>
    </div>
    <div class="stat-card">
      <div class="stat-card-top">
        <div class="label">Ukupno poruka</div>
        <div class="stat-card-icon icon-green">💬</div>
      </div>
      <div class="num"><%= totalMessages %></div>
    </div>
  </div>

  <div class="chart-wrap">
    <div class="chart-header">
      <h2>Poruke po danu</h2>
      <span class="chart-badge">Posljednjih 7 dana</span>
    </div>
    <canvas id="msgChart" height="80"></canvas>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  (function () {
    const today = new Date();
    const labels = [];
    const dataMap = {};

    <% perDay.forEach(function(row) {
      const d = row.day instanceof Date ? row.day.toISOString().slice(0,10) : String(row.day).slice(0,10);
    %>
    dataMap['<%= d %>'] = <%= row.count %>;
    <% }); %>

    for (let i = 6; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(d.getDate() - i);
      labels.push(d.toLocaleDateString('hr-HR', { weekday: 'short', day: 'numeric', month: 'numeric' }));
      const key = d.toISOString().slice(0, 10);
      if (!dataMap[key]) dataMap[key] = 0;
    }

    const values = [];
    for (let i = 6; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(d.getDate() - i);
      values.push(dataMap[d.toISOString().slice(0, 10)] || 0);
    }

    const ctx = document.getElementById('msgChart').getContext('2d');
    const gradient = ctx.createLinearGradient(0, 0, 0, 260);
    gradient.addColorStop(0,   'rgba(37,99,235,0.85)');
    gradient.addColorStop(1,   'rgba(37,99,235,0.15)');

    new Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          label: 'Poruke',
          data: values,
          backgroundColor: gradient,
          borderRadius: 8,
          borderSkipped: false,
          hoverBackgroundColor: 'rgba(37,99,235,1)',
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#0f172a',
            titleColor: '#94a3b8',
            bodyColor: '#fff',
            padding: 10,
            cornerRadius: 8,
            callbacks: {
              label: ctx => ` ${ctx.parsed.y} poruka`
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { precision: 0, color: '#94a3b8', font: { size: 12 } },
            grid: { color: '#f1f5f9', drawBorder: false }
          },
          x: {
            ticks: { color: '#64748b', font: { size: 12 } },
            grid: { display: false }
          }
        }
      }
    });
  })();
</script>

  <!-- Analytics row -->
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:18px;margin-bottom:28px">

    <!-- Intent distribution -->
    <div class="chart-wrap" style="margin-bottom:0">
      <div class="chart-header">
        <h2>Najčešći interesi turista</h2>
        <span class="chart-badge">Po tipu</span>
      </div>
      <% const intentLabels = { faq:'Opće informacije', weather:'Vrijeme', weather_current:'Vrijeme', weather_tomorrow:'Vrijeme', weather_multi:'Vrijeme', events:'Događaji', ai:'Ostalo', other:'Ostalo', fallback:'Ostalo' };
         const intentColors = { faq:'#2563eb', weather:'#0ea5e9', events:'#16a34a', ai:'#7c3aed' };
         const intentTotal  = intents.reduce((s,r) => s + Number(r.count), 0) || 1;
      %>
      <% if (!intents.length) { %>
        <p style="color:#94a3b8;font-size:13px;padding-top:8px">Nema podataka.</p>
      <% } else { intents.forEach(function(r) {
           const pct = Math.round(Number(r.count) / intentTotal * 100);
           const col = intentColors[r.intent] || '#64748b';
           const lbl = intentLabels[r.intent]  || r.intent;
      %>
        <div style="margin-bottom:10px">
          <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
            <span style="font-weight:600;color:#374151"><%= lbl %></span>
            <span style="color:#64748b"><%= r.count %> (<%= pct %>%)</span>
          </div>
          <div style="background:#f1f5f9;border-radius:20px;height:7px;overflow:hidden">
            <div style="width:<%= pct %>%;height:100%;background:<%= col %>;border-radius:20px"></div>
          </div>
        </div>
      <% }); } %>
    </div>

    <!-- Language distribution -->
    <div class="chart-wrap" style="margin-bottom:0">
      <div class="chart-header">
        <h2>Jezici</h2>
        <span class="chart-badge">Distribucija</span>
      </div>
      <% const langLabels = { hr:'🇭🇷 Hrvatski', en:'🇬🇧 English', de:'🇩🇪 Deutsch', it:'🇮🇹 Italiano', fr:'🇫🇷 Français' };
         const langTotal  = languages.reduce((s,r) => s + Number(r.count), 0) || 1;
      %>
      <% if (!languages.length) { %>
        <p style="color:#94a3b8;font-size:13px;padding-top:8px">Nema podataka.</p>
      <% } else { languages.forEach(function(r) {
           const pct = Math.round(Number(r.count) / langTotal * 100);
           const lbl = langLabels[r.lang] || r.lang;
      %>
        <div style="margin-bottom:10px">
          <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
            <span style="font-weight:600;color:#374151"><%= lbl %></span>
            <span style="color:#64748b"><%= r.count %> (<%= pct %>%)</span>
          </div>
          <div style="background:#f1f5f9;border-radius:20px;height:7px;overflow:hidden">
            <div style="width:<%= pct %>%;height:100%;background:#2563eb;border-radius:20px"></div>
          </div>
        </div>
      <% }); } %>
    </div>

    <!-- Activity by time of day -->
    <div class="chart-wrap" style="margin-bottom:0">
      <div class="chart-header">
        <h2>Aktivnost</h2>
        <span class="chart-badge">Po dobu dana</span>
      </div>
      <% const tod = timeOfDay || {};
         const todTotal = (Number(tod.morning)||0) + (Number(tod.afternoon)||0) + (Number(tod.evening)||0) || 1;
         const todSlots = [
           { label:'Jutro',      icon:'🌅', key:'morning',   val: Number(tod.morning)||0,   color:'#f59e0b' },
           { label:'Poslijepodne', icon:'☀️', key:'afternoon', val: Number(tod.afternoon)||0, color:'#2563eb' },
           { label:'Večer',      icon:'🌙', key:'evening',   val: Number(tod.evening)||0,   color:'#7c3aed' },
         ];
      %>
      <% todSlots.forEach(function(s) {
           const pct = Math.round(s.val / todTotal * 100);
      %>
        <div style="margin-bottom:10px">
          <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
            <span style="font-weight:600;color:#374151"><%= s.icon %> <%= s.label %></span>
            <span style="color:#64748b"><%= s.val %></span>
          </div>
          <div style="background:#f1f5f9;border-radius:20px;height:7px;overflow:hidden">
            <div style="width:<%= pct %>%;height:100%;background:<%= s.color %>;border-radius:20px"></div>
          </div>
        </div>
      <% }); %>
    </div>

  </div>

<%- include('partials/foot') %>
