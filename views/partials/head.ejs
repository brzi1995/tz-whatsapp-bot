<!DOCTYPE html>
<html lang="hr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — TZ Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f8fafc; color: #1e293b; }
    .wrapper { display: flex; min-height: 100vh; }

    /* ── Sidebar ── */
    .sidebar { width: 220px; background: #1e293b; color: #cbd5e1; padding: 24px 0; flex-shrink: 0; display: flex; flex-direction: column; }
    .sidebar .logo { font-size: 18px; font-weight: 700; color: #fff; padding: 0 20px 24px; border-bottom: 1px solid #334155; margin-bottom: 8px; }
    .sidebar .logo span { display: block; font-size: 11px; font-weight: 400; color: #64748b; margin-top: 3px; }
    .sidebar a { display: block; padding: 10px 20px; color: #cbd5e1; text-decoration: none; font-size: 14px; }
    .sidebar a:hover, .sidebar a.active { background: #334155; color: #fff; }
    .sidebar .nav-icon { margin-right: 8px; }
    .sidebar-footer { margin-top: auto; padding: 16px 20px; border-top: 1px solid #334155; }
    .sidebar-footer a { padding: 0; color: #94a3b8; font-size: 13px; }
    .sidebar-footer a:hover { background: none; color: #ef4444; }

    /* ── Content ── */
    .content { flex: 1; padding: 32px; overflow-y: auto; min-width: 0; }
    h1 { font-size: 22px; margin-bottom: 20px; font-weight: 700; }
    h2 { font-size: 16px; font-weight: 600; }

    /* ── Cards ── */
    .cards { display: flex; gap: 16px; margin-bottom: 28px; flex-wrap: wrap; }
    .card { background: #fff; border-radius: 10px; padding: 20px 24px; box-shadow: 0 1px 4px rgba(0,0,0,.07); flex: 1; min-width: 140px; }
    .card .num { font-size: 32px; font-weight: 700; color: #3b82f6; }
    .card .label { font-size: 13px; color: #64748b; margin-top: 4px; }

    /* ── Table ── */
    .table-wrap { background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.07); overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 11px 16px; text-align: left; font-size: 14px; border-bottom: 1px solid #f1f5f9; }
    th { font-weight: 600; color: #64748b; font-size: 12px; text-transform: uppercase; background: #f8fafc; }
    tr:last-child td { border-bottom: none; }

    /* ── Buttons ── */
    .btn { display: inline-block; padding: 7px 14px; border-radius: 6px; font-size: 13px; cursor: pointer; border: none; text-decoration: none; font-weight: 500; transition: opacity .15s; }
    .btn:hover { opacity: .88; }
    .btn-primary { background: #3b82f6; color: #fff; }
    .btn-danger { background: #ef4444; color: #fff; }
    .btn-secondary { background: #e2e8f0; color: #1e293b; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }

    /* ── Forms ── */
    input, textarea, select { width: 100%; padding: 8px 12px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 14px; margin-bottom: 12px; background: #fff; color: #1e293b; }
    input:focus, textarea:focus, select:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.12); }
    label { display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 4px; }
    .add-form { background: #fff; border-radius: 10px; padding: 20px; box-shadow: 0 1px 4px rgba(0,0,0,.07); margin-bottom: 24px; }
    .add-form h2 { font-size: 15px; margin-bottom: 14px; }
    .form-row { display: flex; gap: 12px; flex-wrap: wrap; }
    .form-row > * { flex: 1; min-width: 160px; }

    /* ── Chat ── */
    .chat { display: flex; flex-direction: column; gap: 10px; max-width: 680px; }
    .bubble { padding: 10px 14px; border-radius: 12px; max-width: 70%; font-size: 14px; line-height: 1.5; }
    .bubble.user { background: #e2e8f0; align-self: flex-start; border-bottom-left-radius: 3px; }
    .bubble.bot { background: #3b82f6; color: #fff; align-self: flex-end; border-bottom-right-radius: 3px; }
    .bubble .meta { font-size: 11px; opacity: .6; margin-top: 4px; }

    /* ── Takeover bar ── */
    .takeover-bar { background: #fff; border-radius: 10px; padding: 14px 20px; margin-bottom: 20px; display: flex; align-items: center; gap: 14px; box-shadow: 0 1px 4px rgba(0,0,0,.07); flex-wrap: wrap; }
    .badge { padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-on { background: #dcfce7; color: #166534; }
    .badge-off { background: #fee2e2; color: #991b1b; }

    /* ── Chart wrapper ── */
    .chart-wrap { background: #fff; border-radius: 10px; padding: 20px 24px; box-shadow: 0 1px 4px rgba(0,0,0,.07); margin-bottom: 28px; }
    .chart-wrap h2 { font-size: 15px; margin-bottom: 16px; color: #374151; }

    /* ── Alert ── */
    .alert { padding: 10px 14px; border-radius: 6px; font-size: 14px; margin-bottom: 16px; }
    .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }

    /* ── Login page ── */
    .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; background: #f1f5f9; }
    .login-box { background: #fff; border-radius: 12px; padding: 40px 36px; box-shadow: 0 4px 24px rgba(0,0,0,.10); width: 100%; max-width: 380px; }
    .login-box .logo-lg { font-size: 22px; font-weight: 800; color: #1e293b; margin-bottom: 4px; }
    .login-box .sub { font-size: 13px; color: #64748b; margin-bottom: 28px; }
    .login-box input { margin-bottom: 14px; }
    .login-box .btn { width: 100%; text-align: center; padding: 10px; font-size: 15px; }

    /* ── Mobile hamburger ── */
    .hamburger { display: none; background: none; border: none; cursor: pointer; padding: 16px 20px; }
    .hamburger span { display: block; width: 22px; height: 2px; background: #fff; margin: 4px 0; border-radius: 2px; transition: .2s; }
    .sidebar-nav { display: flex; flex-direction: column; flex: 1; }

    /* ── Back link ── */
    .back-link { display: inline-block; font-size: 13px; color: #64748b; text-decoration: none; margin-bottom: 16px; }
    .back-link:hover { color: #1e293b; }

    /* ── Empty state ── */
    .empty { text-align: center; color: #94a3b8; font-size: 14px; padding: 40px 0; }

    @media (max-width: 700px) {
      .wrapper { flex-direction: column; }
      .sidebar { width: 100%; padding: 0; }
      .hamburger { display: block; }
      .sidebar-nav { display: none; }
      .sidebar-nav.open { display: flex; }
      .sidebar .logo { padding: 16px 20px 16px; border-bottom: none; margin-bottom: 0; }
      .sidebar-footer { padding: 10px 20px; }
      .content { padding: 16px; }
      .chat .bubble { max-width: 90%; }
      .form-row { flex-direction: column; }
    }
  </style>
</head>
<body>
<div class="wrapper">
