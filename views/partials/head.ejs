<!DOCTYPE html>
<html lang="hr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — TZ Admin</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue:          #2563eb;
      --blue-light:    #eff6ff;
      --blue-mid:      #bfdbfe;
      --green:         #16a34a;
      --green-light:   #dcfce7;
      --red:           #dc2626;
      --red-light:     #fef2f2;
      --purple:        #7c3aed;
      --purple-light:  #f3e8ff;
      --amber:         #d97706;
      --amber-light:   #fef3c7;
      --sidebar-bg:    #0f172a;
      --sidebar-border:#1e293b;
      --sidebar-text:  #94a3b8;
      --sidebar-hover: #1e293b;
      --sidebar-active:#1d4ed8;
      --bg:            #f1f5f9;
      --surface:       #ffffff;
      --border:        #e2e8f0;
      --text:          #0f172a;
      --muted:         #64748b;
      --shadow-sm:     0 1px 3px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.04);
      --shadow-md:     0 4px 16px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.04);
      --radius:        14px;
      --radius-sm:     9px;
      --radius-xs:     6px;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      font-size: 14px;
    }

    .wrapper { display: flex; min-height: 100vh; }

    /* ── Sidebar ── */
    .sidebar {
      width: 224px;
      background: var(--sidebar-bg);
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }
    .sidebar-logo {
      padding: 20px 18px 16px;
      border-bottom: 1px solid var(--sidebar-border);
    }
    .sidebar-logo .brand {
      font-size: 16px;
      font-weight: 800;
      color: #fff;
      letter-spacing: -.3px;
    }
    .sidebar-logo .brand span { color: #60a5fa; }
    .sidebar-logo .sub { font-size: 11px; color: #475569; margin-top: 2px; }

    .sidebar-nav {
      flex: 1;
      padding: 10px 8px;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }
    .nav-section-label {
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: #334155;
      padding: 10px 10px 4px;
    }
    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: var(--radius-sm);
      color: var(--sidebar-text);
      text-decoration: none;
      font-size: 13.5px;
      font-weight: 500;
      transition: background .15s, color .15s;
    }
    .sidebar-nav a:hover { background: var(--sidebar-hover); color: #e2e8f0; }
    .sidebar-nav a.active { background: var(--sidebar-active); color: #fff; }
    .sidebar-nav a .nav-icon {
      width: 18px;
      height: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .sidebar-nav a .nav-icon svg { width: 16px; height: 16px; stroke-width: 2.2; }
    .sidebar-footer {
      padding: 10px 8px;
      border-top: 1px solid var(--sidebar-border);
    }
    .sidebar-footer a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: var(--radius-sm);
      color: #475569;
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      transition: background .15s, color .15s;
    }
    .sidebar-footer a:hover { background: #1e293b; color: #ef4444; }
    .sidebar-footer a .nav-icon svg { width: 15px; height: 15px; stroke-width: 2.2; }

    /* ── Mobile hamburger ── */
    .hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 14px 18px;
      margin-left: auto;
    }
    .hamburger span {
      display: block;
      width: 20px;
      height: 2px;
      background: #fff;
      margin: 4px 0;
      border-radius: 2px;
    }
    .sidebar-top-row { display: flex; align-items: center; }

    /* ── Content ── */
    .content {
      flex: 1;
      padding: 28px 30px;
      overflow-y: auto;
      min-width: 0;
    }
    .page-header { margin-bottom: 22px; }
    .page-header h1 {
      font-size: 22px;
      font-weight: 800;
      color: var(--text);
      letter-spacing: -.5px;
    }
    .page-header p { font-size: 13px; color: var(--muted); margin-top: 3px; }

    h1 { font-size: 20px; margin-bottom: 18px; font-weight: 800; letter-spacing: -.4px; }
    h2 { font-size: 14px; font-weight: 700; }

    /* ── Stats Grid ── */
    .stats-grid, .cards {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 20px;
      align-items: start;
    }

    /* Hero stat card (total messages) */
    .hero-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 22px 22px 18px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      border-left: 3px solid var(--green);
      display: flex;
      flex-direction: column;
      gap: 6px;
      transition: box-shadow .2s, transform .2s;
    }
    .hero-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
    .hero-card .hero-icon {
      width: 36px;
      height: 36px;
      border-radius: 9px;
      background: var(--green-light);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--green);
      margin-bottom: 2px;
    }
    .hero-card .hero-icon svg { width: 17px; height: 17px; stroke-width: 2.2; }
    .hero-card .label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: var(--muted);
    }
    .hero-card .hero-num {
      font-size: 48px;
      font-weight: 800;
      letter-spacing: -2px;
      line-height: 1;
      color: var(--text);
    }

    /* Secondary stat card */
    .stat-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 16px 18px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: box-shadow .2s, transform .2s;
    }
    .stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
    .stat-card-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
    }
    .stat-card .label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: var(--muted);
    }
    .stat-card-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .stat-card-icon svg { width: 15px; height: 15px; stroke-width: 2.2; }
    .icon-blue   { background: var(--blue-light);   color: var(--blue); }
    .icon-green  { background: var(--green-light);  color: var(--green); }
    .icon-amber  { background: var(--amber-light);  color: var(--amber); }
    .icon-purple { background: var(--purple-light); color: var(--purple); }
    .stat-card .num {
      font-size: 30px;
      font-weight: 800;
      letter-spacing: -1px;
      line-height: 1;
      color: var(--text);
    }
    .stat-card .num-text { font-size: 17px; letter-spacing: -.2px; font-weight: 700; }
    .stat-card .stat-sub { font-size: 11px; color: var(--muted); }

    /* ── Section header ── */
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .section-header h2 { font-size: 14px; font-weight: 700; color: var(--text); }

    /* ── Table (kept as fallback) ── */
    .table-wrap {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      overflow: hidden;
    }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 12px 18px; text-align: left; font-size: 13.5px; border-bottom: 1px solid #f1f5f9; }
    th {
      font-weight: 600;
      color: var(--muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .06em;
      background: #f8fafc;
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fafbfc; }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 10px 18px;
      min-height: 40px;
      border-radius: var(--radius-sm);
      font-size: 13.5px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      text-decoration: none;
      transition: box-shadow .15s, transform .1s, filter .15s, background .15s;
      white-space: nowrap;
      -webkit-tap-highlight-color: transparent;
      line-height: 1;
    }
    .btn:active { transform: scale(.97); }
    .btn svg { width: 14px; height: 14px; flex-shrink: 0; stroke-width: 2.2; }
    .btn-primary  { background: var(--blue); color: #fff; }
    .btn-primary:hover  { filter: brightness(1.08); box-shadow: 0 4px 12px rgba(37,99,235,.28); }
    .btn-danger   { background: var(--red); color: #fff; }
    .btn-danger:hover   { filter: brightness(1.08); }
    .btn-secondary { background: var(--surface); color: var(--text); border: 1px solid var(--border); }
    .btn-secondary:hover { background: #f8fafc; border-color: #cbd5e1; }
    .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
    .btn-ghost:hover { background: #f8fafc; color: var(--text); }
    .btn-sm { padding: 6px 12px; min-height: 32px; font-size: 12.5px; }

    /* ── Forms ── */
    input, textarea, select {
      width: 100%;
      padding: 10px 13px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: 14px;
      margin-bottom: 14px;
      background: var(--surface);
      color: var(--text);
      transition: border-color .15s, box-shadow .15s;
      min-height: 40px;
    }
    textarea { min-height: auto; }
    input:focus, textarea:focus, select:focus {
      outline: none;
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(37,99,235,.1);
    }
    label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: 5px;
    }
    .add-form {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 20px 22px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      margin-bottom: 20px;
    }
    .add-form h2 { font-size: 14px; margin-bottom: 16px; }
    .form-row { display: flex; gap: 14px; flex-wrap: wrap; }
    .form-row > * { flex: 1; min-width: 160px; }

    /* ── Chart wrap ── */
    .chart-wrap {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 18px 20px 16px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      margin-bottom: 16px;
    }
    .chart-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }
    .chart-header h2 { font-size: 14px; font-weight: 700; color: var(--text); }
    .chart-header .chart-badge {
      font-size: 11px;
      font-weight: 600;
      background: var(--blue-light);
      color: var(--blue);
      padding: 3px 10px;
      border-radius: 20px;
    }

    /* ── Uvidi (compact insights) ── */
    .uvidi-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 13px 18px;
      margin-bottom: 16px;
      box-shadow: var(--shadow-sm);
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }
    .uvidi-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: var(--muted);
      white-space: nowrap;
      padding-top: 2px;
    }
    .uvidi-label svg { width: 12px; height: 12px; vertical-align: middle; margin-right: 4px; stroke-width: 2.5; }
    .uvidi-items { display: flex; flex-wrap: wrap; gap: 6px; flex: 1; }
    .uvidi-item {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 12.5px;
      color: var(--text);
      background: #f8fafc;
      border: 1px solid var(--border);
      border-radius: var(--radius-xs);
      padding: 4px 10px;
      font-weight: 500;
    }
    .uvidi-empty { font-size: 13px; color: var(--muted); padding-top: 2px; }

    /* ── Item Cards (card-based list) ── */
    .item-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 20px;
    }
    .item-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 18px;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      box-shadow: var(--shadow-sm);
      transition: box-shadow .15s, transform .15s;
    }
    .item-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
    .item-card-body { flex: 1; min-width: 0; }
    .item-card-title {
      font-weight: 700;
      font-size: 14px;
      color: var(--text);
      margin-bottom: 4px;
      line-height: 1.4;
    }
    .item-card-meta { font-size: 12.5px; color: var(--muted); line-height: 1.6; }
    .item-card-actions {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
      flex-wrap: wrap;
    }

    /* ── Tags ── */
    .tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 20px;
      white-space: nowrap;
      vertical-align: middle;
    }
    .tag-amber  { background: var(--amber-light); color: #92400e; }
    .tag-blue   { background: var(--blue-light);  color: var(--blue); }
    .tag-green  { background: var(--green-light); color: var(--green); }
    .tag-gray   { background: #f1f5f9; color: var(--muted); }

    /* ── Badges ── */
    .badge { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; }
    .badge-on  { background: var(--green-light); color: var(--green); }
    .badge-off { background: var(--red-light);   color: var(--red); }

    /* ── Alert ── */
    .alert { padding: 11px 16px; border-radius: var(--radius-sm); font-size: 14px; margin-bottom: 16px; }
    .alert-error { background: var(--red-light); color: var(--red); border: 1px solid #fca5a5; }

    /* ── Login ── */
    .login-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
    }
    .login-box {
      background: var(--surface);
      border-radius: 16px;
      padding: 44px 40px;
      box-shadow: 0 20px 60px rgba(0,0,0,.25);
      width: 100%;
      max-width: 400px;
    }
    .login-box .logo-lg {
      font-size: 24px;
      font-weight: 800;
      color: var(--text);
      letter-spacing: -.5px;
      margin-bottom: 4px;
    }
    .login-box .logo-lg span { color: var(--blue); }
    .login-box .sub { font-size: 13px; color: var(--muted); margin-bottom: 32px; }
    .login-box .btn { width: 100%; padding: 12px; font-size: 15px; }

    /* ── Back link ── */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: 18px;
    }
    .back-link:hover { color: var(--text); }

    /* ── Empty state ── */
    .empty { text-align: center; color: #94a3b8; font-size: 14px; padding: 48px 0; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .wrapper { flex-direction: column; }
      .sidebar { width: 100%; height: auto; position: relative; }
      .sidebar-top-row { display: flex; justify-content: space-between; align-items: center; }
      .hamburger { display: block; }
      .sidebar-nav { display: none; padding: 8px 8px; }
      .sidebar-nav.open { display: flex; }
      .sidebar-footer { display: none; }
      .sidebar-footer.open { display: block; padding: 8px; }
      .content { padding: 16px; }
      .stats-grid, .cards { grid-template-columns: 1fr 1fr; }
      .stats-grid .hero-card, .cards .hero-card { grid-column: 1 / -1; }
      .form-row { flex-direction: column; }
      .login-box { margin: 16px; padding: 32px 24px; }
      .item-card { flex-direction: column; }
      .item-card-actions { width: 100%; justify-content: flex-start; }
      .btn { min-height: 44px; }
      .btn-sm { min-height: 40px; padding: 8px 14px; font-size: 13px; }
      .uvidi-card { flex-direction: column; gap: 8px; }
    }
    @media (max-width: 400px) {
      .item-card-actions .btn { flex: 1; }
    }
  </style>
</head>
<body>
<div class="wrapper">
