<!DOCTYPE html>
<html lang="hr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — TZ Admin</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue:          #3b82f6;
      --blue-light:    rgba(59,130,246,0.12);
      --blue-mid:      rgba(59,130,246,0.25);
      --green:         #10b981;
      --green-light:   rgba(16,185,129,0.12);
      --red:           #ef4444;
      --red-light:     rgba(239,68,68,0.12);
      --purple:        #8b5cf6;
      --purple-light:  rgba(139,92,246,0.12);
      --amber:         #f59e0b;
      --amber-light:   rgba(245,158,11,0.12);
      --sidebar-bg:    #0a0a0c;
      --sidebar-border:#1a1a1d;
      --sidebar-text:  #52525b;
      --sidebar-hover: rgba(255,255,255,0.04);
      --bg:            #0f0f11;
      --surface:       #161618;
      --surface-2:     #1e1e21;
      --border:        #27272a;
      --text:          #ededef;
      --muted:         #71717a;
      --ease:          cubic-bezier(.4, 0, .2, 1);
      --shadow-xs:     0 1px 3px rgba(0,0,0,0.6);
      --shadow-sm:     0 2px 12px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.03);
      --shadow-md:     0 8px 32px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.05);
      --shadow-lg:     0 20px 60px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.05);
      --radius:        16px;
      --radius-sm:     10px;
      --radius-xs:     6px;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.55;
      font-size: 14px;
      -webkit-font-smoothing: antialiased;
    }

    /* Subtle ambient glow in the background */
    body::before {
      content: '';
      position: fixed;
      top: -20%;
      left: -5%;
      width: 55vw;
      height: 55vh;
      background: radial-gradient(ellipse at center, rgba(59,130,246,0.035) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }
    body::after {
      content: '';
      position: fixed;
      bottom: -20%;
      right: -5%;
      width: 50vw;
      height: 50vh;
      background: radial-gradient(ellipse at center, rgba(139,92,246,0.03) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    .wrapper { display: flex; min-height: 100vh; position: relative; z-index: 1; }

    /* ── Sidebar ───────────────────────────────────────────── */
    .sidebar {
      width: 220px;
      background: var(--sidebar-bg);
      border-right: 1px solid var(--sidebar-border);
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }
    .sidebar-logo {
      padding: 22px 18px 18px;
      border-bottom: 1px solid var(--sidebar-border);
    }
    .sidebar-logo .brand {
      font-size: 15px;
      font-weight: 800;
      color: #fff;
      letter-spacing: -.5px;
    }
    .sidebar-logo .brand span {
      background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .sidebar-logo .sub { font-size: 11px; color: #27272a; margin-top: 3px; }

    .sidebar-nav {
      flex: 1;
      padding: 10px 8px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .nav-section-label {
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: #27272a;
      padding: 10px 10px 4px;
    }
    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 11px;
      border-radius: var(--radius-sm);
      color: var(--sidebar-text);
      text-decoration: none;
      font-size: 13.5px;
      font-weight: 500;
      transition: background .15s var(--ease), color .15s var(--ease);
      position: relative;
    }
    .sidebar-nav a:hover { background: var(--sidebar-hover); color: #a1a1aa; }
    .sidebar-nav a.active {
      background: rgba(59,130,246,0.1);
      color: #93c5fd;
    }
    .sidebar-nav a.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 22%;
      bottom: 22%;
      width: 2px;
      background: linear-gradient(180deg, #3b82f6, #8b5cf6);
      border-radius: 0 2px 2px 0;
      box-shadow: 0 0 8px rgba(59,130,246,0.7);
    }
    .sidebar-nav a .nav-icon {
      width: 18px; height: 18px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      opacity: 0.7;
    }
    .sidebar-nav a.active .nav-icon { opacity: 1; }
    .sidebar-nav a .nav-icon svg { width: 16px; height: 16px; stroke-width: 1.8; }

    .sidebar-footer {
      padding: 10px 8px;
      border-top: 1px solid var(--sidebar-border);
    }
    .sidebar-footer a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 11px;
      border-radius: var(--radius-sm);
      color: #3f3f46;
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      transition: background .15s var(--ease), color .15s var(--ease);
    }
    .sidebar-footer a:hover { background: rgba(239,68,68,0.08); color: #f87171; }
    .sidebar-footer a .nav-icon svg { width: 15px; height: 15px; stroke-width: 1.8; }

    /* hamburger */
    .hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 14px 18px;
      margin-left: auto;
    }
    .hamburger span {
      display: block; width: 20px; height: 2px;
      background: #3f3f46; margin: 4px 0; border-radius: 2px;
      transition: background .15s;
    }
    .sidebar-top-row { display: flex; align-items: center; }

    /* ── Content ───────────────────────────────────────────── */
    .content {
      flex: 1;
      padding: 32px 32px 48px;
      overflow-y: auto;
      min-width: 0;
      max-width: 980px;
    }
    .page-header { margin-bottom: 28px; }
    .page-header h1 {
      font-size: 22px;
      font-weight: 800;
      color: var(--text);
      letter-spacing: -.6px;
    }
    .page-header p { font-size: 13px; color: var(--muted); margin-top: 4px; }

    h1 { font-size: 20px; margin-bottom: 20px; font-weight: 800; letter-spacing: -.5px; }
    h2 { font-size: 13.5px; font-weight: 700; letter-spacing: -.1px; color: var(--text); }

    /* ── Stats Grid ─────────────────────────────────────────── */
    .stats-grid, .cards {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 20px;
      align-items: start;
    }

    /* ── Card inner shimmer (shared mixin) ── */
    .hero-card, .stat-card, .chart-wrap, .item-card, .add-form, .uvidi-strip {
      position: relative;
      overflow: hidden;
    }
    .hero-card::after, .stat-card::after, .chart-wrap::after,
    .item-card::after, .add-form::after, .uvidi-strip::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
      pointer-events: none;
    }

    /* Hero card */
    .hero-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 22px 24px 20px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 6px;
      transition: box-shadow .25s var(--ease), transform .2s var(--ease), border-color .25s;
    }
    .hero-card:hover {
      box-shadow: var(--shadow-md), 0 0 28px rgba(16,185,129,0.12);
      transform: translateY(-2px);
      border-color: rgba(16,185,129,0.2);
    }
    .hero-card .hero-icon {
      width: 38px; height: 38px;
      border-radius: 11px;
      background: rgba(16,185,129,0.1);
      border: 1px solid rgba(16,185,129,0.18);
      display: flex; align-items: center; justify-content: center;
      color: var(--green);
      margin-bottom: 2px;
    }
    .hero-card .hero-icon svg { width: 17px; height: 17px; stroke-width: 2; }
    .hero-card .label {
      font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .08em;
      color: var(--muted);
    }
    .hero-card .hero-num {
      font-size: 48px;
      font-weight: 800;
      letter-spacing: -3px;
      line-height: 1;
      background: linear-gradient(150deg, #ededef 20%, #52525b 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Secondary stat cards */
    .stat-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 18px 20px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: box-shadow .25s var(--ease), transform .2s var(--ease), border-color .25s;
    }
    .stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .stat-card-top { display: flex; align-items: flex-start; justify-content: space-between; }
    .stat-card .label {
      font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .08em;
      color: var(--muted);
    }
    .stat-card-icon {
      width: 34px; height: 34px; border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; border: 1px solid transparent;
    }
    .stat-card-icon svg { width: 15px; height: 15px; stroke-width: 2; }
    .icon-blue   { background: rgba(59,130,246,0.1);  color: #60a5fa; border-color: rgba(59,130,246,0.18); }
    .icon-green  { background: rgba(16,185,129,0.1);  color: #34d399; border-color: rgba(16,185,129,0.18); }
    .icon-amber  { background: rgba(245,158,11,0.1);  color: #fbbf24; border-color: rgba(245,158,11,0.18); }
    .icon-purple { background: rgba(139,92,246,0.1);  color: #a78bfa; border-color: rgba(139,92,246,0.18); }
    .stat-card .num {
      font-size: 32px; font-weight: 800;
      letter-spacing: -1.5px; line-height: 1;
      color: var(--text);
    }
    .stat-card .num-text { font-size: 18px; letter-spacing: -.3px; font-weight: 700; }
    .stat-card .stat-sub { font-size: 11.5px; color: var(--muted); }

    /* ── Section header ─────────────────────────────────────── */
    .section-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 12px;
    }
    .section-header h2 { font-size: 13.5px; font-weight: 700; color: var(--text); }

    /* ── Chart wrap ─────────────────────────────────────────── */
    .chart-wrap {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 20px 22px 18px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      margin-bottom: 16px;
    }
    .chart-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 18px;
    }
    .chart-header h2 { font-size: 13.5px; font-weight: 700; color: var(--text); }
    .chart-header .chart-badge {
      font-size: 11px; font-weight: 600;
      background: rgba(59,130,246,0.1);
      color: #60a5fa;
      padding: 3px 10px; border-radius: 20px;
      border: 1px solid rgba(59,130,246,0.18);
    }

    /* ── Uvidi strip ────────────────────────────────────────── */
    .uvidi-strip {
      display: flex; align-items: center; flex-wrap: wrap;
      gap: 0; padding: 13px 20px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 16px;
      box-shadow: var(--shadow-xs);
    }
    .uvidi-strip-title {
      font-size: 10.5px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .09em;
      color: var(--muted); margin-right: 14px; white-space: nowrap;
    }
    .uvidi-strip-title svg {
      width: 11px; height: 11px; vertical-align: middle;
      margin-right: 4px; stroke-width: 2.5; color: #a78bfa;
    }
    .uvidi-strip-items {
      display: flex; align-items: center; flex-wrap: wrap; gap: 0; flex: 1;
    }
    .uvidi-strip-item {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 12.5px; color: var(--text); font-weight: 500; padding: 2px 0;
    }
    .uvidi-strip-sep { color: #3f3f46; margin: 0 10px; font-size: 13px; line-height: 1; }

    /* ── Table ──────────────────────────────────────────────── */
    .table-wrap {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      overflow: hidden;
    }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 12px 18px; text-align: left; font-size: 13.5px; border-bottom: 1px solid var(--border); }
    th {
      font-weight: 700; color: var(--muted);
      font-size: 11px; text-transform: uppercase; letter-spacing: .07em;
      background: rgba(255,255,255,0.02);
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,0.02); }

    /* ── Buttons ────────────────────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      padding: 9px 17px; min-height: 38px;
      border-radius: var(--radius-sm);
      font-size: 13.5px; font-weight: 600;
      cursor: pointer; border: none; text-decoration: none;
      transition: box-shadow .2s var(--ease), transform .15s var(--ease), background .15s var(--ease);
      white-space: nowrap; -webkit-tap-highlight-color: transparent; line-height: 1;
    }
    .btn:active { transform: scale(.96) !important; }
    .btn:hover  { transform: translateY(-1px) scale(1.02); }
    .btn svg { width: 14px; height: 14px; flex-shrink: 0; stroke-width: 2; }

    .btn-primary {
      background: linear-gradient(135deg, #1d4ed8, #3b82f6);
      color: #fff;
      border: 1px solid rgba(59,130,246,0.35);
    }
    .btn-primary:hover { box-shadow: 0 4px 20px rgba(59,130,246,0.35), 0 0 0 1px rgba(59,130,246,0.3); }

    .btn-danger {
      background: linear-gradient(135deg, #991b1b, #ef4444);
      color: #fff;
      border: 1px solid rgba(239,68,68,0.3);
    }
    .btn-danger:hover { box-shadow: 0 4px 16px rgba(239,68,68,0.3); }

    .btn-secondary {
      background: var(--surface-2);
      color: var(--text);
      border: 1px solid var(--border);
    }
    .btn-secondary:hover {
      background: rgba(255,255,255,0.04);
      border-color: rgba(255,255,255,0.1);
      box-shadow: var(--shadow-xs);
    }
    .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
    .btn-ghost:hover { background: rgba(255,255,255,0.04); color: var(--text); }
    .btn-sm { padding: 5px 12px; min-height: 30px; font-size: 12.5px; }

    /* ── Forms ──────────────────────────────────────────────── */
    input, textarea, select {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #dcdcdc;
      border-radius: 10px;
      font-size: 14px;
      margin-bottom: 14px;
      background: #ffffff;
      color: #111111;
      transition: border-color .15s var(--ease), box-shadow .15s var(--ease);
      min-height: 40px;
    }
    textarea { min-height: auto; }
    input:focus, textarea:focus, select:focus {
      outline: none;
      border-color: #3b82f6;
      box-shadow: 0 0 0 2px rgba(59,130,246,0.15);
    }
    input::placeholder, textarea::placeholder { color: #888888; }
    select option { background: #ffffff; color: #111111; }
    label {
      display: block;
      font-size: 13px; font-weight: 600; color: #555555;
      margin-bottom: 5px;
    }
    .add-form {
      background: #ffffff;
      border-radius: var(--radius);
      padding: 24px 26px;
      box-shadow: 0 1px 6px rgba(0,0,0,0.06);
      border: 1px solid #e4e4e7;
      margin-bottom: 20px;
    }
    .add-form h2 { font-size: 14px; margin-bottom: 18px; color: #111111; font-weight: 700; }
    .form-row { display: flex; gap: 14px; flex-wrap: wrap; }
    .form-row > * { flex: 1; min-width: 160px; }

    /* ── Item Cards ─────────────────────────────────────────── */
    .item-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
    .item-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 18px;
      display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
      box-shadow: var(--shadow-sm);
      transition: box-shadow .2s var(--ease), transform .2s var(--ease), border-color .2s;
    }
    .item-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-1px);
      border-color: rgba(255,255,255,0.07);
    }
    .item-card-body { flex: 1; min-width: 0; }
    .item-card-title { font-weight: 700; font-size: 14px; color: var(--text); margin-bottom: 4px; line-height: 1.4; }
    .item-card-meta { font-size: 12.5px; color: var(--muted); line-height: 1.6; }
    .item-card-actions { display: flex; align-items: center; gap: 6px; flex-shrink: 0; flex-wrap: wrap; }

    /* ── Tags ───────────────────────────────────────────────── */
    .tag { display: inline-block; font-size: 11px; font-weight: 600; padding: 2px 9px; border-radius: 20px; white-space: nowrap; vertical-align: middle; }
    .tag-amber  { background: rgba(245,158,11,0.1);  color: #fbbf24; border: 1px solid rgba(245,158,11,0.2); }
    .tag-blue   { background: rgba(59,130,246,0.1);  color: #60a5fa; border: 1px solid rgba(59,130,246,0.2); }
    .tag-green  { background: rgba(16,185,129,0.1);  color: #34d399; border: 1px solid rgba(16,185,129,0.2); }
    .tag-gray   { background: rgba(255,255,255,0.05); color: var(--muted); border: 1px solid var(--border); }

    /* ── Badges ─────────────────────────────────────────────── */
    .badge { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; }
    .badge-on  { background: rgba(16,185,129,0.1); color: #34d399; border: 1px solid rgba(16,185,129,0.2); }
    .badge-off { background: rgba(239,68,68,0.1);  color: #f87171; border: 1px solid rgba(239,68,68,0.2); }

    /* ── Alert ──────────────────────────────────────────────── */
    .alert { padding: 12px 16px; border-radius: var(--radius-sm); font-size: 14px; margin-bottom: 16px; }
    .alert-error { background: rgba(239,68,68,0.1); color: #f87171; border: 1px solid rgba(239,68,68,0.2); }

    /* ── Login ──────────────────────────────────────────────── */
    .login-wrap {
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh; background: var(--bg);
      position: relative; overflow: hidden;
    }
    .login-box {
      background: var(--surface);
      border-radius: 20px;
      padding: 44px 40px;
      box-shadow: var(--shadow-lg);
      width: 100%; max-width: 400px;
      position: relative; z-index: 1;
      border: 1px solid var(--border);
    }
    .login-box .logo-lg {
      font-size: 24px; font-weight: 800; color: var(--text);
      letter-spacing: -.6px; margin-bottom: 4px;
    }
    .login-box .logo-lg span {
      background: linear-gradient(135deg, #60a5fa, #a78bfa);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .login-box .sub { font-size: 13px; color: var(--muted); margin-bottom: 32px; }
    .login-box .btn { width: 100%; padding: 12px; font-size: 15px; }

    /* ── Back link ──────────────────────────────────────────── */
    .back-link {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 13px; color: var(--muted); text-decoration: none;
      margin-bottom: 18px; transition: color .15s var(--ease);
    }
    .back-link:hover { color: var(--text); }

    /* ── Empty state ────────────────────────────────────────── */
    .empty { text-align: center; color: var(--muted); font-size: 14px; padding: 48px 0; }

    /* ── Responsive ─────────────────────────────────────────── */
    @media (max-width: 768px) {
      .wrapper { flex-direction: column; }
      .sidebar { width: 100%; height: auto; position: relative; }
      .sidebar-top-row { display: flex; justify-content: space-between; align-items: center; }
      .hamburger { display: block; }
      .sidebar-nav { display: none; padding: 8px; }
      .sidebar-nav.open { display: flex; }
      .sidebar-footer { display: none; }
      .sidebar-footer.open { display: block; padding: 8px; }
      .content { padding: 16px 16px 32px; max-width: 100%; }
      .stats-grid, .cards { grid-template-columns: 1fr 1fr; }
      .stats-grid .hero-card, .cards .hero-card { grid-column: 1 / -1; }
      .form-row { flex-direction: column; }
      .login-box { margin: 16px; padding: 32px 24px; }
      .item-card { flex-direction: column; }
      .item-card-actions { width: 100%; justify-content: flex-start; }
      .btn { min-height: 44px; }
      .btn-sm { min-height: 40px; padding: 8px 14px; font-size: 13px; }
      .uvidi-strip { flex-direction: column; align-items: flex-start; gap: 8px; }
      .uvidi-strip-sep { display: none; }
      .uvidi-strip-items { gap: 6px; flex-direction: column; align-items: flex-start; }
    }
    @media (max-width: 400px) {
      .item-card-actions .btn { flex: 1; }
    }
  </style>
</head>
<body>
<div class="wrapper">
