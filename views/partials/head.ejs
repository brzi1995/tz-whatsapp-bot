<!DOCTYPE html>
<html lang="hr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — TZ Admin</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue:          #0A7EA4;
      --blue-light:    rgba(10,126,164,0.12);
      --blue-mid:      rgba(10,126,164,0.25);
      --green:         #16a34a;
      --green-light:   rgba(22,163,74,0.12);
      --red:           #dc2626;
      --red-light:     rgba(220,38,38,0.12);
      --purple:        #7c3aed;
      --purple-light:  rgba(124,58,237,0.12);
      --amber:         #D95F2B;
      --amber-light:   rgba(217,95,43,0.12);
      --sidebar-bg:    #FAF7F2;
      --sidebar-border:#DDD8CE;
      --sidebar-text:  #5C6880;
      --sidebar-hover: rgba(10,126,164,0.07);
      --bg:            #FAF7F2;
      --surface:       #FFFFFF;
      --surface-2:     #F3EFE8;
      --border:        #DDD8CE;
      --text:          #1A1A2E;
      --muted:         #6B7A99;
      --muted-strong:  #5C6880; /* za tekst <14px ili gdje je potreban veći kontrast */
      --ease:          cubic-bezier(.4, 0, .2, 1);
      --shadow-xs:     0 1px 2px rgba(26,26,46,0.06);
      --shadow-sm:     0 1px 3px rgba(26,26,46,0.05), 0 4px 12px rgba(26,26,46,0.06);
      --shadow-md:     0 2px 6px rgba(26,26,46,0.05), 0 8px 24px rgba(26,26,46,0.09);
      --shadow-lg:     0 4px 12px rgba(26,26,46,0.06), 0 16px 48px rgba(26,26,46,0.12);
      --radius:        16px;
      --radius-sm:     10px;
      --radius-xs:     6px;

      /* Typography scale */
      --fs-xs:    11px;   /* badges, tag labels, table th, chart tick labels */
      --fs-sm:    12px;   /* kpi-sub, muted captions, pill text, feat-desc */
      --fs-body:  13.5px; /* nav links, table td, item-card-title meta */
      --fs-base:  14px;   /* body default, form inputs, labels, item-card-title */
      --fs-md:    15px;   /* panel h2, section subheadings */
      --fs-lg:    18px;   /* stat-card .num-text */
      --fs-xl:    22px;   /* page-header h1 */
      --fs-2xl:   26px;   /* dashboard hero h1 */
      --fs-3xl:   32px;   /* stat-card big numbers */

      /* Line heights */
      --lh-tight:   1.25;  /* headings */
      --lh-snug:    1.4;   /* card titles, labels */
      --lh-normal:  1.55;  /* body */
      --lh-relaxed: 1.65;  /* longer body copy, FAQ answers */

      /* Font weights */
      --fw-normal:  400;
      --fw-medium:  500;
      --fw-semibold:600;
      --fw-bold:    700;
      --fw-black:   800;

      /* Letter spacing */
      --ls-tight:  -0.5px;  /* large headings */
      --ls-normal:  0;
      --ls-wide:    0.04em;  /* small caps labels */
      --ls-wider:   0.08em;  /* UPPERCASE eyebrows/badges */
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: var(--lh-normal);
      font-size: var(--fs-base);
      -webkit-font-smoothing: antialiased;
    }

    /* Subtle ambient glow in the background */
    body::before {
      content: '';
      position: fixed;
      top: -20%;
      left: -5%;
      width: 55vw;
      height: 55vh;
      background: radial-gradient(ellipse at center, rgba(10,126,164,0.05) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }
    body::after {
      content: '';
      position: fixed;
      bottom: -20%;
      right: -5%;
      width: 50vw;
      height: 50vh;
      background: radial-gradient(ellipse at center, rgba(217,95,43,0.04) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    .wrapper { display: flex; min-height: 100vh; position: relative; z-index: 1; }

    /* ── Sidebar ───────────────────────────────────────────── */
    .sidebar {
      width: 220px;
      background: var(--sidebar-bg);
      border-right: 1px solid var(--sidebar-border);
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }
    .sidebar-logo {
      padding: 22px 18px 18px;
      border-bottom: 1px solid var(--sidebar-border);
    }
    .sidebar-logo .brand {
      font-size: 15px;
      font-weight: 800;
      color: var(--text);
      letter-spacing: -.5px;
    }
    .sidebar-logo .brand span {
      background: linear-gradient(135deg, #0A7EA4 0%, #38b2d4 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .sidebar-logo .sub { font-size: 11px; color: #5C6880; margin-top: 3px; }

    .sidebar-nav {
      flex: 1;
      padding: 10px 8px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .nav-section-label {
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: #8A96B0;
      padding: 8px 10px 4px;
    }
    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 11px;
      border-radius: var(--radius-sm);
      color: var(--sidebar-text);
      text-decoration: none;
      font-size: var(--fs-body);
      font-weight: 500;
      transition: background .15s var(--ease), color .15s var(--ease);
      position: relative;
    }
    .sidebar-nav a:hover { background: var(--sidebar-hover); color: var(--text); }
    .sidebar-nav a.active {
      background: rgba(10,126,164,0.1);
      color: #0A7EA4;
    }
    .sidebar-nav a.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 22%;
      bottom: 22%;
      width: 2px;
      background: linear-gradient(180deg, #0A7EA4, #38b2d4);
      border-radius: 0 2px 2px 0;
      box-shadow: 0 0 8px rgba(10,126,164,0.4);
    }
    .sidebar-nav a .nav-icon {
      width: 18px; height: 18px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      opacity: 0.6;
      transition: opacity .15s var(--ease);
    }
    .sidebar-nav a:hover .nav-icon { opacity: 0.9; }
    .sidebar-nav a.active .nav-icon { opacity: 1; }
    .sidebar-nav a .nav-icon svg { width: 16px; height: 16px; stroke-width: 1.8; }

    .sidebar-footer {
      padding: 10px 8px;
      border-top: 1px solid var(--sidebar-border);
    }
    .sidebar-footer a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 11px;
      border-radius: var(--radius-sm);
      color: #5C6880;
      text-decoration: none;
      font-size: var(--fs-body);
      font-weight: 500;
      transition: background .15s var(--ease), color .15s var(--ease);
    }
    .sidebar-footer a:hover { background: rgba(220,38,38,0.07); color: #dc2626; }
    .sidebar-footer a .nav-icon svg { width: 15px; height: 15px; stroke-width: 1.8; }

    /* hamburger */
    .hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 14px 18px;
      margin-left: auto;
    }
    .hamburger span {
      display: block; width: 20px; height: 2px;
      background: var(--muted); margin: 4px 0; border-radius: 2px;
      transition: background .15s;
    }
    .sidebar-top-row { display: flex; align-items: center; }

    /* ── Content ───────────────────────────────────────────── */
    .content {
      flex: 1;
      padding: 24px 32px 40px;
      overflow-y: auto;
      min-width: 0;
      max-width: 980px;
    }
    .page-header { margin-bottom: 22px; }
    .page-header h1 {
      font-size: var(--fs-xl);
      font-weight: 800;
      color: var(--text);
      letter-spacing: var(--ls-tight);
      line-height: var(--lh-tight);
    }
    .page-header p { font-size: var(--fs-body); color: #5C6880; margin-top: 4px; line-height: var(--lh-normal); }

    h1 { font-size: var(--fs-xl); margin-bottom: 20px; font-weight: 800; letter-spacing: var(--ls-tight); line-height: var(--lh-tight); }
    h2 { font-size: var(--fs-body); font-weight: 700; letter-spacing: -.1px; color: var(--text); line-height: var(--lh-snug); }

    /* ── Stats Grid ─────────────────────────────────────────── */
    .stats-grid, .cards {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 20px;
      align-items: start;
    }

    /* ── Card inner shimmer (shared mixin) ── */
    .hero-card, .stat-card, .chart-wrap, .item-card, .add-form, .uvidi-strip {
      position: relative;
      overflow: hidden;
    }
    .hero-card::after, .stat-card::after, .chart-wrap::after,
    .item-card::after, .add-form::after, .uvidi-strip::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(0,0,0,0.04), transparent);
      pointer-events: none;
    }

    /* Hero card */
    .hero-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 22px 24px 20px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 6px;
      transition: box-shadow .25s var(--ease), transform .2s var(--ease), border-color .25s;
    }
    .hero-card:hover {
      box-shadow: var(--shadow-md), 0 0 28px rgba(10,126,164,0.10);
      transform: translateY(-2px);
      border-color: rgba(10,126,164,0.2);
    }
    .hero-card .hero-icon {
      width: 38px; height: 38px;
      border-radius: 11px;
      background: rgba(16,185,129,0.1);
      border: 1px solid rgba(16,185,129,0.18);
      display: flex; align-items: center; justify-content: center;
      color: var(--green);
      margin-bottom: 2px;
    }
    .hero-card .hero-icon svg { width: 17px; height: 17px; stroke-width: 2; }
    .hero-card .label {
      font-size: var(--fs-xs); font-weight: 700;
      text-transform: uppercase; letter-spacing: var(--ls-wider);
      color: #5C6880;
    }
    .hero-card .hero-num {
      font-size: 48px;
      font-weight: 800;
      letter-spacing: -3px;
      line-height: 1;
      background: linear-gradient(150deg, #1A1A2E 20%, #4A5568 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Secondary stat cards */
    .stat-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 18px 20px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: box-shadow .25s var(--ease), transform .2s var(--ease), border-color .25s;
    }
    .stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .stat-card-top { display: flex; align-items: flex-start; justify-content: space-between; }
    .stat-card .label {
      font-size: var(--fs-xs); font-weight: 700;
      text-transform: uppercase; letter-spacing: var(--ls-wider);
      color: #5C6880;
    }
    .stat-card-icon {
      width: 34px; height: 34px; border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; border: 1px solid transparent;
    }
    .stat-card-icon svg { width: 15px; height: 15px; stroke-width: 2; }
    .icon-blue   { background: rgba(10,126,164,0.1);   color: #0A7EA4; border-color: rgba(10,126,164,0.2); }
    .icon-green  { background: rgba(22,163,74,0.1);   color: #16a34a; border-color: rgba(22,163,74,0.2); }
    .icon-amber  { background: rgba(217,95,43,0.1);   color: #D95F2B; border-color: rgba(217,95,43,0.2); }
    .icon-purple { background: rgba(124,58,237,0.1);  color: #7c3aed; border-color: rgba(124,58,237,0.2); }
    .stat-card .num {
      font-size: var(--fs-3xl); font-weight: 800;
      letter-spacing: -1.5px; line-height: 1;
      color: var(--text);
    }
    .stat-card .num-text { font-size: var(--fs-lg); letter-spacing: -.3px; font-weight: 700; }
    .stat-card .stat-sub { font-size: var(--fs-xs); color: #5C6880; }

    /* ── Section header ─────────────────────────────────────── */
    .section-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 12px;
    }
    .section-header h2 { font-size: var(--fs-body); font-weight: 700; color: var(--text); }

    /* ── Chart wrap ─────────────────────────────────────────── */
    .chart-wrap {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 20px 22px 18px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      margin-bottom: 16px;
    }
    .chart-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 18px;
    }
    .chart-header h2 { font-size: var(--fs-body); font-weight: 700; color: var(--text); }
    .chart-header .chart-badge {
      font-size: var(--fs-xs); font-weight: 600;
      background: rgba(10,126,164,0.1);
      color: #0A7EA4;
      padding: 3px 10px; border-radius: 20px;
      border: 1px solid rgba(10,126,164,0.2);
    }

    /* ── Uvidi strip ────────────────────────────────────────── */
    .uvidi-strip {
      display: flex; align-items: center; flex-wrap: wrap;
      gap: 0; padding: 13px 20px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 16px;
      box-shadow: var(--shadow-xs);
    }
    .uvidi-strip-title {
      font-size: var(--fs-xs); font-weight: 700;
      text-transform: uppercase; letter-spacing: var(--ls-wider);
      color: #5C6880; margin-right: 14px; white-space: nowrap;
    }
    .uvidi-strip-title svg {
      width: 11px; height: 11px; vertical-align: middle;
      margin-right: 4px; stroke-width: 2.5; color: #0A7EA4;
    }
    .uvidi-strip-items {
      display: flex; align-items: center; flex-wrap: wrap; gap: 0; flex: 1;
    }
    .uvidi-strip-item {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: var(--fs-sm); color: var(--text); font-weight: 500; padding: 2px 0;
    }
    .uvidi-strip-sep { color: var(--border); margin: 0 10px; font-size: 13px; line-height: 1; }

    /* ── Table ──────────────────────────────────────────────── */
    .table-wrap {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      overflow: hidden;
    }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 12px 18px; text-align: left; font-size: var(--fs-body); border-bottom: 1px solid var(--border); line-height: var(--lh-snug); }
    th {
      font-weight: 700; color: #5C6880;
      font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: var(--ls-wide);
      background: rgba(0,0,0,0.02); line-height: var(--lh-snug);
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(0,0,0,0.02); }

    /* ── Buttons ────────────────────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      padding: 9px 17px; min-height: 38px;
      border-radius: var(--radius-sm);
      font-size: var(--fs-body); font-weight: 600;
      cursor: pointer; border: none; text-decoration: none;
      transition: box-shadow .2s var(--ease), transform .15s var(--ease), background .15s var(--ease), border-color .15s var(--ease);
      white-space: nowrap; -webkit-tap-highlight-color: transparent; line-height: 1;
    }
    .btn:active { transform: scale(0.97) !important; box-shadow: none !important; }
    .btn svg { width: 14px; height: 14px; flex-shrink: 0; stroke-width: 2; }
    .btn-sm svg { width: 13px; height: 13px; }

    .btn-primary {
      background: linear-gradient(135deg, #076d8e, #0A7EA4);
      color: #fff;
      border: 1px solid rgba(10,126,164,0.35);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      background: linear-gradient(135deg, #087fa0, #0c90bb);
      box-shadow: 0 6px 20px rgba(10,126,164,0.28);
    }
    .btn-primary:active { background: linear-gradient(135deg, #076d8e, #076d8e); }
    .btn-primary:focus-visible { outline: 2px solid #0A7EA4; outline-offset: 3px; }

    .btn-danger {
      background: linear-gradient(135deg, #991b1b, #ef4444);
      color: #fff;
      border: 1px solid rgba(239,68,68,0.3);
    }
    .btn-danger:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(239,68,68,0.3); }
    .btn-danger:focus-visible { outline: 2px solid #dc2626; outline-offset: 3px; }

    .btn-secondary {
      background: var(--surface-2);
      color: var(--text);
      border: 1px solid var(--border);
    }
    .btn-secondary:hover {
      background: #EAE5DC;
      border-color: #C4BFB4;
      box-shadow: var(--shadow-xs);
    }
    .btn-secondary:active { background: #DDD8CE; }
    .btn-secondary:focus-visible { outline: 2px solid #0A7EA4; outline-offset: 3px; }

    .btn-ghost { background: transparent; color: #5C6880; border: 1px solid var(--border); }
    .btn-ghost:hover {
      background: rgba(10,126,164,0.06);
      border-color: rgba(10,126,164,0.25);
      color: #0A7EA4;
    }
    .btn-ghost:focus-visible { outline: 2px solid #0A7EA4; outline-offset: 3px; }

    .btn-sm { padding: 5px 12px; min-height: 30px; font-size: var(--fs-sm); }

    .kpi-icon svg { stroke-width: 2; }
    .stat-card-icon svg { stroke-width: 2; }

    /* ── Forms ──────────────────────────────────────────────── */
    input, textarea, select {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #DDD8CE;
      border-radius: 10px;
      font-size: var(--fs-base);
      margin-bottom: 14px;
      background: #ffffff;
      color: #111111;
      transition: border-color .15s var(--ease), box-shadow .15s var(--ease);
      min-height: 40px;
    }
    textarea { min-height: auto; }
    input:hover:not(:focus):not(:disabled), textarea:hover:not(:focus):not(:disabled), select:hover:not(:focus):not(:disabled) {
      border-color: #C4BFBA;
    }
    input:focus, textarea:focus, select:focus {
      outline: none;
      border-color: #0A7EA4;
      box-shadow: 0 0 0 2px rgba(10,126,164,0.15);
    }
    input:disabled, textarea:disabled, select:disabled {
      background: var(--surface-2);
      color: var(--muted);
      border-color: var(--border);
      cursor: not-allowed;
      opacity: 0.6;
    }
    input[type="checkbox"] { accent-color: #0A7EA4; }
    input::placeholder, textarea::placeholder { color: #888888; }
    select option { background: #ffffff; color: #111111; }
    label {
      display: block;
      font-size: var(--fs-body); font-weight: 600; color: #3D4559;
      margin-bottom: 5px; line-height: var(--lh-snug);
    }
    .add-form {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 24px 26px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      margin-bottom: 20px;
    }
    .add-form h2 { font-size: var(--fs-base); margin-bottom: 18px; color: var(--text); font-weight: 700; }
    .form-row { display: flex; gap: 14px; flex-wrap: wrap; }
    .form-row > * { flex: 1; min-width: 160px; }

    /* ── Item Cards ─────────────────────────────────────────── */
    .item-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
    .item-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 18px;
      display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
      box-shadow: var(--shadow-sm);
      transition: box-shadow .2s var(--ease), transform .2s var(--ease), border-color .2s;
    }
    .item-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-1px);
      border-color: rgba(10,126,164,0.2);
    }
    .item-card-body { flex: 1; min-width: 0; }
    .item-card-title { font-weight: 700; font-size: var(--fs-base); color: var(--text); margin-bottom: 4px; line-height: var(--lh-snug); }
    .item-card-meta { font-size: var(--fs-sm); color: #5C6880; line-height: var(--lh-relaxed); /* muted OK: 12px+ with relaxed leading */ }
    .item-card-actions { display: flex; align-items: center; gap: 6px; flex-shrink: 0; flex-wrap: wrap; }

    /* ── Tags ───────────────────────────────────────────────── */
    .tag { display: inline-block; font-size: var(--fs-xs); font-weight: 600; padding: 2px 9px; border-radius: 20px; white-space: nowrap; vertical-align: middle; }
    .tag-amber  { background: rgba(217,95,43,0.1);   color: #A84620; border: 1px solid rgba(217,95,43,0.22); }
    .tag-blue   { background: rgba(10,126,164,0.1);  color: #0A7EA4; border: 1px solid rgba(10,126,164,0.22); }
    .tag-green  { background: rgba(22,163,74,0.1);   color: #16a34a; border: 1px solid rgba(22,163,74,0.22); }
    .tag-gray   { background: rgba(0,0,0,0.04);      color: #5C6880; border: 1px solid var(--border); }

    /* ── Badges ─────────────────────────────────────────────── */
    .badge { padding: 4px 12px; border-radius: 20px; font-size: var(--fs-sm); font-weight: 700; }
