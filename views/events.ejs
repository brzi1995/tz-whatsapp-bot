<%- include('partials/head', { title: 'Događaji' }) %>
<%- include('partials/sidebar', { activePage: 'events' }) %>

<main class="content">
  <div class="page-header">
    <h1>Događaji</h1>
    <p>Upravljajte događajima koje bot šalje turistima</p>
  </div>

  <div class="add-form">
    <h2>Dodaj novi događaj</h2>
    <form method="POST" action="/admin/events">
      <div class="form-row">
        <div>
          <label>Naziv</label>
          <input type="text" name="title" placeholder="Npr. Ljetni festival" required>
        </div>
        <div>
          <label>Datum</label>
          <input type="date" name="date">
        </div>
      </div>
      <label>Lokacija (link)</label>
      <input type="text" name="location_link" placeholder="Npr. https://osm.org/...">
      <label>Opis</label>
      <textarea name="description" rows="2" placeholder="Kratki opis događaja..."></textarea>
      <div class="ev-form-footer">
        <div class="ev-checks">
          <label class="feat-check">
            <input type="checkbox" name="featured" value="1">
            <span>⭐ Istakni događaj</span>
            <span class="feat-check-hint">— bot ga šalje kao prioritet</span>
          </label>
          <label class="feat-check">
            <input type="checkbox" name="send_notification" value="1">
            <span>📣 Pošalji obavijest turistima</span>
            <span class="feat-check-hint">— šalje WhatsApp svim turistima</span>
          </label>
        </div>
        <button type="submit" class="btn btn-primary">
          <i data-lucide="plus"></i> Dodaj događaj
        </button>
      </div>
    </form>
  </div>

  <%# ── Import from brela.hr ─────────────────────────────────────────── %>
  <div class="add-form" style="margin-top:16px">
    <h2>Uvezi s brela.hr</h2>
    <p style="font-size:13px;color:var(--muted);margin:0 0 12px">Automatski dohvati događaje s brela.hr/dogadanja za odabrani mjesec.</p>
    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
      <input type="month" id="importMonth" value="<%= new Date().toISOString().slice(0,7) %>" style="max-width:180px">
      <button id="importBtn" class="btn btn-primary" onclick="runImport()">
        <i data-lucide="download"></i> Uvezi događaje
      </button>
      <span id="importStatus" style="font-size:13px;color:var(--muted)"></span>
    </div>
  </div>

  <%# ── List controls ───────────────────────────────────────────────── %>
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:12px">
    <div style="font-size:13px;color:var(--muted)">
      <%= events.length %> događaj<%= events.length === 1 ? '' : 'a' %>
      <% if (!showInactive) { %>
        &nbsp;·&nbsp;<a href="/admin/events?showInactive=1" style="color:var(--blue);text-decoration:none">Prikaži neaktivne</a>
      <% } else { %>
        &nbsp;(uključujući neaktivne) ·&nbsp;<a href="/admin/events" style="color:var(--blue);text-decoration:none">Sakrij neaktivne</a>
      <% } %>
    </div>
  </div>

  <% if (events.length === 0) { %>
    <div class="empty">Nema događaja. Dodajte prvi gore ili uvezite s brela.hr.</div>
  <% } else { %>
    <div class="item-list">
      <% events.forEach(function(ev) {
           const dateStr = ev.date
             ? new Date(ev.date).toLocaleDateString('hr-HR', { day:'numeric', month:'long', year:'numeric' })
             : null;
           const isActive = ev.is_active !== 0;
           const categoryLabels = {
             festival: 'Festival', sport: 'Sport', concert: 'Koncert',
             gastronomy: 'Gastronomija', family: 'Obitelj', exhibition: 'Izložba',
             traditional: 'Tradicija', nightlife: 'Noćni život',
           };
      %>
      <div class="item-card<%= isActive ? '' : ' item-card--inactive' %>">
        <div class="item-card-body">
          <div class="item-card-title">
            <%= ev.title %>
            <% if (ev.featured) { %>
              <span class="tag tag-amber" style="margin-left:6px">⭐ Izdvojeno</span>
            <% } %>
            <% if (!isActive) { %>
              <span class="tag" style="margin-left:6px;background:var(--surface-2);color:var(--muted)">Neaktivno</span>
            <% } %>
            <% if (ev.category && categoryLabels[ev.category]) { %>
              <span class="tag tag-blue" style="margin-left:6px"><%= categoryLabels[ev.category] %></span>
            <% } %>
          </div>
          <div class="item-card-meta">
            <% if (dateStr) { %><i data-lucide="calendar" style="width:12px;height:12px;vertical-align:middle;margin-right:3px"></i><%= dateStr %><% } %>
            <% if (ev.location_link) { %>&nbsp;·&nbsp;<a href="<%= ev.location_link %>" target="_blank" style="color:var(--blue);text-decoration:none">📍 Lokacija</a><% } %>
            <% if (ev.description) { %><br><%= ev.description %><% } %>
          </div>
        </div>
        <div class="item-card-actions">
          <form method="POST" action="/admin/events/<%= ev.id %>/toggle-active">
            <button type="submit" class="btn btn-sm" title="<%= isActive ? 'Deaktiviraj' : 'Aktiviraj' %>"
              style="background:<%= isActive ? 'var(--surface-2)' : '#dcfce7' %>;color:<%= isActive ? '#71717a' : '#16a34a' %>;border:1px solid <%= isActive ? 'var(--border)' : '#bbf7d0' %>">
              <%= isActive ? '⏸' : '▶' %>
            </button>
          </form>
          <form method="POST" action="/admin/events/<%= ev.id %>/toggle-featured">
            <button type="submit" class="btn btn-sm" title="<%= ev.featured ? 'Ukloni isticanje' : 'Istakni' %>"
              style="background:<%= ev.featured ? 'var(--amber-light)' : 'var(--surface-2)' %>;color:<%= ev.featured ? 'var(--amber)' : '#71717a' %>;border:1px solid <%= ev.featured ? '#fde68a' : 'var(--border)' %>">
              <%= ev.featured ? '⭐' : '☆' %>
            </button>
          </form>
          <a href="/admin/events/<%= ev.id %>/edit" class="btn btn-secondary btn-sm">
            <i data-lucide="pencil"></i> Uredi
          </a>
          <form method="POST" action="/admin/events/<%= ev.id %>/delete" onsubmit="return confirm('Obrisati ovaj događaj?')">
            <button type="submit" class="btn btn-danger btn-sm">
              <i data-lucide="trash-2"></i> Briši
            </button>
          </form>
        </div>
      </div>
      <% }); %>
    </div>
  <% } %>
</main>

<style>
.ev-form-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 4px;
}
.feat-check {
  display: flex;
  align-items: center;
  gap: 6px;
  text-transform: none;
  letter-spacing: 0;
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  cursor: pointer;
  margin: 0;
}
.feat-check input[type="checkbox"] { width: auto; margin: 0; accent-color: var(--blue); }
.feat-check-hint { font-size: 12px; font-weight: 400; color: var(--muted); }
.ev-checks { display: flex; flex-direction: column; gap: 8px; }
.item-card--inactive { opacity: 0.55; }
.tag-blue { background: #dbeafe; color: #1d4ed8; }
</style>

<script>
async function runImport() {
  const month = document.getElementById('importMonth').value;
  const btn   = document.getElementById('importBtn');
  const status = document.getElementById('importStatus');

  if (!month) { status.textContent = 'Odaberite mjesec.'; return; }

  btn.disabled = true;
  status.textContent = 'Uvoz u tijeku…';

  try {
    const res = await fetch('/admin/import-events', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ month }),
    });
    const data = await res.json();
    if (data.error) {
      status.textContent = 'Greška: ' + data.error;
    } else {
      status.textContent = `Uvezeno: ${data.imported} · Preskočeno: ${data.skipped ?? 0} · Greške: ${data.errors ?? 0}`;
      if (data.imported > 0) setTimeout(() => location.reload(), 1200);
    }
  } catch (e) {
    status.textContent = 'Mrežna greška.';
  } finally {
    btn.disabled = false;
  }
}
</script>

<%- include('partials/foot') %>
