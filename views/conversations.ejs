<%- include('partials/head', { title: 'Razgovori' }) %>
<%- include('partials/sidebar', { activePage: 'conversations' }) %>

<main class="content">
  <div class="page-header">
    <h1>Razgovori</h1>
    <p>Pregled svih razgovora s turistima</p>
  </div>

  <% if (!conversations || conversations.length === 0) { %>
    <div class="empty">Nema razgovora još.</div>
  <% } else { %>
    <div style="display:flex;flex-direction:column;gap:10px">
      <% conversations.forEach(function(c) {
           const lastMsg    = c.last_msg ? new Date(c.last_msg).toLocaleString('hr-HR') : '—';
           const cleanPhone = (c.user_phone || '').replace('whatsapp:', '');
           const encoded    = encodeURIComponent(c.user_phone || '');
           const inTakeover = Boolean(c.human_takeover);
      %>
      <a href="/admin/conversations/<%= encoded %>" style="text-decoration:none;display:block">
        <div style="background:var(--surface);border-radius:var(--radius);border:1px solid var(--border);padding:16px 20px;box-shadow:var(--shadow-sm);display:flex;align-items:center;gap:16px;transition:box-shadow .2s,transform .15s"
             onmouseover="this.style.cssText+='box-shadow:var(--shadow-md);transform:translateY(-1px)'"
             onmouseout="this.style.boxShadow='var(--shadow-sm)';this.style.transform='none'">

          <div style="width:44px;height:44px;background:#eff6ff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">💬</div>

          <div style="flex:1;min-width:0">
            <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:5px"><%= cleanPhone %></div>
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
              <span style="background:#eff6ff;color:#1d4ed8;padding:2px 9px;border-radius:20px;font-size:12px;font-weight:600"><%= c.msg_count %> poruka</span>
              <span style="color:var(--muted);font-size:12px"><%= lastMsg %></span>
              <span style="padding:2px 9px;border-radius:20px;font-size:12px;font-weight:600;background:<%= inTakeover ? '#fef2f2' : '#f0fdf4' %>;color:<%= inTakeover ? '#dc2626' : '#16a34a' %>">
                <%= inTakeover ? '🔴 Human takeover' : '🟢 Bot active' %>
              </span>
            </div>
          </div>

          <span style="color:var(--muted);font-size:20px;flex-shrink:0">›</span>
        </div>
      </a>
      <% }); %>
    </div>
  <% } %>
</main>

<%- include('partials/foot') %>
