<%- include('partials/head', { title: 'Obavijesti' }) %>
<%- include('partials/sidebar', { activePage: 'broadcast' }) %>

<main class="content">
  <div class="page-header">
    <h1>Obavijesti</h1>
    <p>WhatsApp obavijesti za prijavljene turiste</p>
  </div>

  <% if (justSent) { %>
    <div style="background:var(--green-light);border:1px solid #86efac;border-radius:var(--radius);padding:13px 18px;margin-bottom:20px;color:var(--green);font-weight:600;font-size:14px">
      ✅ Obavijest je uspješno poslana
    </div>
  <% } %>

  <!-- Subscriber count -->
  <div class="bc-stat">
    <% if (optedInCount === 0) { %>
      📭 Još nema prijavljenih korisnika
    <% } else { %>
      👥 <strong><%= optedInCount %></strong> pretplaćenih korisnika
    <% } %>
  </div>

  <!-- Events queued for notification -->
  <% if (events && events.length > 0) { %>
    <div class="item-list">
      <% events.forEach(ev => {
           const dateStr = ev.date
             ? new Date(ev.date).toLocaleDateString('hr-HR', { day:'numeric', month:'long', year:'numeric' })
             : null;
           const isSent = ev.notification_status === 'sent';
      %>
        <div class="item-card">
          <div class="item-card-body">
            <div class="item-card-title">
              <%= ev.title %>
              <% if (isSent) { %>
                <span class="tag tag-green" style="margin-left:6px">✅ Poslano</span>
              <% } else { %>
                <span class="tag tag-amber" style="margin-left:6px">⏳ Na čekanju</span>
              <% } %>
            </div>
            <div class="item-card-meta">
              <% if (dateStr) { %><i data-lucide="calendar" style="width:12px;height:12px;vertical-align:middle;margin-right:3px"></i><%= dateStr %><% } %>
              <% if (ev.description) { %><br><%= ev.description %><% } %>
            </div>
          </div>
          <div class="item-card-actions">
            <% if (optedInCount > 0) { %>
              <form method="POST" action="/admin/broadcast/<%= ev.id %>/send"
                    onsubmit="return confirm('Poslati obavijest za ovaj događaj?')">
                <button type="submit" class="btn btn-primary btn-sm">
                  <i data-lucide="send"></i> Pošalji sada
                </button>
              </form>
            <% } %>
            <form method="POST" action="/admin/broadcast/<%= ev.id %>/remove"
                  onsubmit="return confirm('Ukloniti iz obavijesti?')">
              <button type="submit" class="btn btn-secondary btn-sm">
                <i data-lucide="x"></i> Ukloni
              </button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="empty">
      Nema događaja označenih za obavijest.<br>
      <a href="/admin/events" style="color:var(--blue);text-decoration:none;font-weight:600;display:inline-block;margin-top:8px">Označi događaj za obavijest →</a>
    </div>
  <% } %>
</main>

<style>
.bc-stat {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px 18px;
  margin-bottom: 20px;
  font-size: 14px;
  color: var(--text);
  box-shadow: var(--shadow-sm);
}
</style>

<%- include('partials/foot') %>
