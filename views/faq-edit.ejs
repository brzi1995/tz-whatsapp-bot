<%- include('partials/head', { title: 'Uredi FAQ' }) %>
<%- include('partials/sidebar', { activePage: 'faq' }) %>

<main class="content">
  <a href="/admin/faq" class="back-link">&#8592; Natrag na FAQ</a>
  <h1>Uredi FAQ unos</h1>

  <div class="add-form" style="max-width:620px">
    <form method="POST" action="/admin/faq/<%= faq.id %>/edit">
      <label>Pitanje</label>
      <input type="text" name="question" value="<%= faq.question %>" required>

      <label>Odgovor</label>
      <textarea name="answer" rows="5" required><%= faq.answer %></textarea>

      <div class="faq-link-section">
        <div class="faq-link-section-label"><i data-lucide="link" style="width:13px;height:13px;vertical-align:middle;margin-right:5px"></i>Link kartica <span style="font-weight:400;color:var(--muted)">(opcionalno)</span></div>
        <div class="form-row">
          <div>
            <label>Naslov linka</label>
            <input type="text" name="link_title" value="<%= faq.link_title || '' %>" placeholder="Npr. Rezerviraj online">
          </div>
          <div>
            <label>URL linka</label>
            <input type="url" name="link_url" value="<%= faq.link_url || '' %>" placeholder="https://...">
          </div>
        </div>
        <label>URL slike <span style="font-weight:400;color:var(--muted);text-transform:none;letter-spacing:0">(slika za pregled kartice)</span></label>
        <input type="url" name="link_image" value="<%= faq.link_image || '' %>" placeholder="https://... (.jpg, .png, ...)">

        <% if (faq.link_url || faq.link_image) { %>
          <div style="margin-top:12px">
            <div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">Pregled kartice</div>
            <a href="<%= faq.link_url || '#' %>" target="_blank" rel="noopener" class="faq-link-card">
              <% if (faq.link_image) { %>
                <img src="<%= faq.link_image %>"
                     class="faq-link-card-img"
                     alt=""
                     onerror="this.style.display='none'">
              <% } %>
              <div class="faq-link-card-body">
                <div class="faq-link-card-title"><%= faq.link_title || faq.link_url %></div>
                <% if (faq.link_url) { %>
                  <div class="faq-link-card-url"><%= faq.link_url %></div>
                <% } %>
              </div>
            </a>
          </div>
        <% } %>
      </div>

      <div style="display:flex;gap:10px">
        <button type="submit" class="btn btn-primary">Spremi promjene</button>
        <a href="/admin/faq" class="btn btn-secondary">Odustani</a>
      </div>
    </form>
  </div>
</main>

<style>
.faq-link-section {
  background: #f8fafc;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 14px 16px;
  margin-bottom: 16px;
}
.faq-link-section-label {
  font-size: 12px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12px;
  text-transform: none;
  letter-spacing: 0;
}
.faq-link-section input {
  background: var(--surface);
}
.faq-link-card {
  display: block;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  overflow: hidden;
  max-width: 260px;
  text-decoration: none;
  color: inherit;
  box-shadow: var(--shadow-xs);
  transition: box-shadow .2s var(--ease), transform .18s var(--ease);
}
.faq-link-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.faq-link-card-img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}
.faq-link-card-body {
  padding: 9px 11px 10px;
  background: var(--surface);
}
.faq-link-card-title {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--text);
  line-height: 1.35;
}
.faq-link-card-url {
  font-size: 11px;
  color: var(--muted);
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
</style>

<%- include('partials/foot') %>
