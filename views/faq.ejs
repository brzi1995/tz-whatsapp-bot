<%- include('partials/head', { title: 'FAQ' }) %>
<%- include('partials/sidebar', { activePage: 'faq' }) %>

<main class="content">
  <div class="page-header">
    <h1>FAQ</h1>
    <p>Pitanja i odgovori koje bot šalje turistima</p>
  </div>

  <div class="add-form">
    <h2>Dodaj novi unos</h2>
    <form method="POST" action="/admin/faq">
      <label>Pitanje</label>
      <input type="text" name="question" placeholder="Npr. Kada je otvorena plaža?" required>
      <label>Odgovor</label>
      <textarea name="answer" rows="3" placeholder="Unesite odgovor..." required></textarea>
      <button type="submit" class="btn btn-primary">
        <i data-lucide="plus"></i> Dodaj
      </button>
    </form>
  </div>

  <% if (faqs.length === 0) { %>
    <div class="empty">Nema FAQ unosa. Dodajte prvi unos gore.</div>
  <% } else { %>
    <div class="item-list">
      <% faqs.forEach(function(f) { %>
      <div class="item-card">
        <div class="item-card-body">
          <div class="item-card-title"><%= f.question %></div>
          <div class="item-card-meta"><%= f.answer %></div>
        </div>
        <div class="item-card-actions">
          <a href="/admin/faq/<%= f.id %>/edit" class="btn btn-secondary btn-sm">
            <i data-lucide="pencil"></i> Uredi
          </a>
          <form method="POST" action="/admin/faq/<%= f.id %>/delete" onsubmit="return confirm('Obrisati ovaj unos?')">
            <button type="submit" class="btn btn-danger btn-sm">
              <i data-lucide="trash-2"></i> Briši
            </button>
          </form>
        </div>
      </div>
      <% }); %>
    </div>
  <% } %>
</main>

<%- include('partials/foot') %>
